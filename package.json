{
  "name": "pierrondi-site",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start -p $PORT",
    "test": "node --import tsx --test $(find test -name '*.test.mjs' | sort | tr '\\n' ' ')",
    "lint": "eslint .",
    "control:tower:dev": "node scripts/control-tower-dev.mjs",
    "automation:collect": "/opt/homebrew/bin/python3 scripts/automation-control-snapshot.py",
    "automation:push": "/opt/homebrew/bin/python3 scripts/automation-control-snapshot.py --post",
    "authority:validate": "node scripts/authority/validate-content.mjs",
    "design:sync-21st": "node scripts/design-vault-sync.mjs",
    "design:install": "node scripts/design-vault-install.mjs",
    "access:snapshot": "node scripts/access-snapshot.mjs",
    "test:apps": "node scripts/check-apps-urls.mjs",
    "test:apps:prod": "TARGET_URL=https://www.pierrondi.dev node scripts/check-apps-urls.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@react-three/fiber": "^9.6.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.40.0",
    "geist": "^1.7.0",
    "gsap": "^3.15.0",
    "lenis": "^1.3.23",
    "lucide-react": "^1.7.0",
    "next": "16.2.6",
    "postcss": "8.5.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "simplex-noise": "^4.0.3",
    "tailwind-merge": "^3.5.0",
    "three": "^0.184.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.184.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "playwright": "^1.60.0",
    "prettier": "^3.8.1",
    "tailwindcss": "^4",
    "tsx": "^4.23.0",
    "typescript": "^5"
  }
}
