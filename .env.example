# pierrondi-site — public landing
# Zero DB. Only Formspree + optional analytics.

# Formspree endpoint (default embedded in api/contact route)
FORMSPREE_URL=https://formspree.io/f/xpqoodnr
NEXT_PUBLIC_FORMSPREE_URL=https://formspree.io/f/xpqoodnr

# Plausible analytics (optional)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=pierrondi.dev

# Site URL (used in metadata + JSON-LD)
NEXT_PUBLIC_SITE_URL=https://pierrondi.dev

# WhatsApp number displayed in the floating CTA (E.164 format, with country code)
NEXT_PUBLIC_WHATSAPP_NUMBER=5511999999999

# Private automation control pane (/automacoes)
# Values live in Railway Variables / local secret storage, never in Git.
AUTOMATION_CONTROL_VIEW_TOKEN=replace-with-random-view-token
AUTOMATION_CONTROL_INGEST_TOKEN=replace-with-random-ingest-token
AUTOMATION_CONTROL_DATA_DIR=/tmp/pierrondi-automation-control
AUTOMATION_CONTROL_URL=https://www.pierrondi.dev/api/automation-control/snapshot

# Control Tower flags
# Set to 1/true/yes to allow public actions without session.
CONTROL_TOWER_PUBLIC_ACTIONS=0

# Creative Control ingestion auth (/api/creative-control/snapshot)
CREATIVE_CONTROL_INGEST_TOKEN=replace-with-random-ingest-token

# FaithSchool magic link integration (used by creative-control auth)
FAITHSCHOOL_MAGIC_LINK_SECRET=replace-with-random-secret
FAITHSCHOOL_MAGIC_URL=https://faithschool.example.com/magic

# Local Control Tower dev server (scripts/control-tower-dev.mjs)
CONTROL_TOWER_PORT=3014

# Smoke test config (scripts/check-apps-urls.mjs)
TARGET_URL=https://www.pierrondi.dev
CHECK_TIMEOUT_MS=10000
CHECK_RETRIES=2
